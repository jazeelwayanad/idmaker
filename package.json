{
  "name": "idmaker",
  "version": "1.0.0",
  "description": "Bulk ID Card Production System",
  "main": "build-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently \".\\node_modules\\.bin\\next dev -p 3000\" \"wait-on http://127.0.0.1:3000 && .\\node_modules\\.bin\\electron .\"",
    "build": ".\\node_modules\\.bin\\next build && .\\node_modules\\.bin\\tsc --project tsconfig.electron.json",
    "start": ".\\node_modules\\.bin\\electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": {
    "name": "Eucodes",
    "email": "info@eucodes.in"
  },
  "license": "MIT",
  "dependencies": {
    "archiver": "^6.0.2",
    "bwip-js": "^4.5.1",
    "fabric": "^6.5.4",
    "framer-motion": "^11.11.11",
    "lucide-react": "^0.454.0",
    "next": "^14.2.16",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "sharp": "^0.33.5",
    "sqlite3": "^5.1.6",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/node": "^20.17.6",
    "@types/pdfkit": "^0.13.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sqlite3": "^3.1.11",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "npmRebuild": false,
    "files": [
      "build-electron/electron/**/*",
      "out/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "appId": "com.eucodes.idmaker",
    "productName": "ID Maker",
    "icon": "assets/icon.ico"
  }
}